# Copy this file to .env.local for local development
# Add all of these as Environment Variables in Vercel dashboard

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # NOT the anon key — keep this server-side only

# ── Resend ────────────────────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=re_your_api_key

# The "from" address — must be a domain you've verified in Resend.
# During testing you can use: onboarding@resend.dev  (Resend's sandbox address)
EMAIL_FROM=oe@obiemeka.com

# Where booking notifications go (defaults to oe@obiemeka.com if not set)
NOTIFY_EMAIL=oe@obiemeka.com
